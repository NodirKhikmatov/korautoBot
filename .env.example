# ──────────────────────────────────────────────
# Korea Auto Market — Environment Variables
# Copy to .env.local and fill in values.
# Validated at runtime via src/config/env.ts
# ──────────────────────────────────────────────

# App (client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon PostgreSQL (server only)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Telegram Mini App (server only)
TELEGRAM_BOT_TOKEN=

# Session signing (server only — optional, falls back to TELEGRAM_BOT_TOKEN)
SESSION_SECRET=

# Cloudflare R2 (server only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://your-bucket.r2.dev
