# ──────────────────────────────────────────────
# Korea Auto Market — Environment Variables
# Copy to .env.local (dev) or .env.production (VPS)
# Validated at runtime via src/config/env.ts
# ──────────────────────────────────────────────

# App (client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (server only)
# Local Postgres:
DATABASE_URL=postgresql://korea_auto_market:password@127.0.0.1:5432/korea_auto_market
# Neon — use sslmode=verify-full (not require) to avoid pg SSL deprecation warning:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=verify-full
# Optional: force SSL for non-URL configs
# DATABASE_SSL=true
# Connection pool size per Node process (default 10)
# DATABASE_POOL_MAX=10

# Telegram Mini App (server only)
TELEGRAM_BOT_TOKEN=

# Local browser testing (npm run dev or start:local on localhost)
# ALLOW_DEV_AUTH=true
# DEV_AUTH_TELEGRAM_ID=999000001

# Session signing (server only — required in production, min 32 chars)
SESSION_SECRET=

# Admin dashboard (server only — comma-separated Telegram user IDs)
ADMIN_TELEGRAM_IDS=

# Cloudflare R2 (server only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public bucket URL from R2 → bucket → Settings → Public access (NOT dash.cloudflare.com)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
