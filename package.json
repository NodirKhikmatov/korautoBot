{
  "name": "korea-auto-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && npm run prepare:standalone",
    "start": "node .next/standalone/server.js",
    "start:local": "node scripts/start-standalone-local.mjs",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:apply-0001": "node scripts/apply-migration-0001.mjs",
    "db:sync-journal": "node scripts/sync-migration-journal.mjs",
    "db:fix": "node scripts/db-fix.mjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "docker:build": "docker build -t korea-auto-market:local --target runner .",
    "db:migrate:prod": "node scripts/run-migrations.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.67.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.3",
    "lucide-react": "^0.477.0",
    "next": "^15.2.1",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "pg": "^8.14.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.8.2"
  }
}
